# Django Settings
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-backend-app-name.onrender.com,localhost,127.0.0.1

# Database (Neon.tech PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://venue-mind.vercel.app,http://localhost:3000

# AI / LLM
GROQ_API_KEY=your-groq-api-key-here

# Celery (optional — only if using background tasks)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Frontend (Vercel)
NEXT_PUBLIC_API_URL=https://your-backend-app-name.onrender.com/api
NEXT_PUBLIC_WS_URL=wss://your-backend-app-name.onrender.com/ws
